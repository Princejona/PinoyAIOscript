#!/bin/bash
# Upgraded Script for Debian 11 with Final Summary - Powered By: ™YModified™

# 1. Initial Setup
apt update
apt install -y sudo curl wget

# Script Variables
HOST='185.61.137.173';
USER='pinoyvpn3_mainpanel';
PASS='apu%kd6kbV5q';
DBNAME='pinoyvpn3_mainpanel';
PORT_TCP='1194';
PORT_UDP='110';
PORT_SSL='443';
API_LINK='https://pinoyvpn.qzz.io/api/authentication/premium';
API_KEY='Pinoy@2026';

# Setup DNS at Domain
wget -O autodns "https://raw.githubusercontent.com/Princejona/PinoyAIOscript/refs/heads/main/5in1" && chmod +x autodns && sed -i -e 's/\r$//' ~/autodns && ./autodns

DOMAIN="$(cat /root/subdomain 2>/dev/null || echo 'Not Set')"
NS="$(cat /root/ns.txt 2>/dev/null || echo 'Not Set')"

timedatectl set-timezone Asia/Riyadh

install_require () {
    echo "Installing Dependencies..."
    systemctl stop firewalld disable firewalld 2>/dev/null
    systemctl stop nftables disable nftables 2>/dev/null
    systemctl stop ufw disable ufw 2>/dev/null
    
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export DEBIAN_FRONTEND=noninteractive
    
    apt update
    apt install -y lsof tar systemd dbus git gnupg2 ca-certificates lsb-release \
    debian-archive-keyring socat python3 python-is-python3 iptables openvpn \
    netcat-openbsd httpie php neofetch vnstat screen squid stunnel4 dropbear \
    gnutls-bin dos2unix nano unzip jq virt-what net-tools default-mysql-client \
    mlocate build-essential fail2ban

    systemctl start cron && systemctl enable cron
    mkdir -p /usr/local/bin /usr/local/var /usr/local/var/run /root/.web
    clear
}

install_squid(){
    echo "Installing Squid..."
    apt install -y squid
    systemctl stop squid
    mv /etc/squid/squid.conf /etc/squid/squid.conf.bak
    MYIP=$(curl -s https://api.ipify.org)
    
    cat <<EOF > /etc/squid/squid.conf
acl YModified dst $MYIP
http_port 8080
http_port 8181
visible_hostname Proxy
acl PURGE method PURGE
acl HEAD method HEAD
acl POST method POST
acl GET method GET
acl CONNECT method CONNECT
http_access allow YModified
http_reply_access allow all
http_access deny all
icp_access allow all
always_direct allow all
error_directory /usr/share/squid/errors/English
EOF
    systemctl restart squid

    wget 'https://raw.githubusercontent.com/TheVinci23/Socks/main/5n1' -O /etc/socks.py
    dos2unix /etc/socks.py && chmod +x /etc/socks.py
}

install_openvpn() {
    echo "Installing OpenVPN..."
    mkdir -p /etc/openvpn/easy-rsa/keys /etc/openvpn/login /etc/openvpn/server
    
    # DNS Fix
    echo -e 'DNS=1.1.1.1\nDNSStubListener=no' >> /etc/systemd/resolved.conf
    systemctl restart systemd-resolved

    # Configs
    cat <<EOF > /etc/openvpn/server.conf
dev tun
port $PORT_UDP
proto udp
server 10.10.0.0 255.255.0.0
ca /etc/openvpn/easy-rsa/keys/ca.crt
cert /etc/openvpn/easy-rsa/keys/server.crt
key /etc/openvpn/easy-rsa/keys/server.key
dh none
ncp-disable
tls-server
tls-version-min 1.2
cipher none
auth none
keepalive 10 120
user nobody
group nogroup
username-as-common-name
verify-client-cert none
script-security 3
auth-user-pass-verify "/etc/openvpn/login/auth_vpn" via-env
push "redirect-gateway def1 bypass-dhcp"
log /etc/openvpn/server/udpserver.log
EOF

    # Copy to TCP
    sed 's/proto udp/proto tcp/; s/port '"$PORT_UDP"'/port '"$PORT_TCP"'/; s/10.10.0.0/10.20.0.0/' /etc/openvpn/server.conf > /etc/openvpn/server2.conf

    # Certificates (Simplified placeholders for copy-paste)
