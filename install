# ---------------------------------------------------------
# FINAL MENU FUNCTION
# ---------------------------------------------------------
show_summary() {
    MYIP=$(curl -s https://api.ipify.org)
    clear
    echo "======================================================"
    echo "       INSTALLATION COMPLETE - SERVER DETAILS"
    echo "======================================================"
    echo "  Server IP        : $MYIP"
    echo "  Domain           : $DOMAIN"
    echo "  Nameserver       : $NS"
    echo "------------------------------------------------------"
    echo "  OpenVPN TCP Port : $PORT_TCP"
    echo "  OpenVPN UDP Port : $PORT_UDP"
    echo "  SSL/Stunnel Port : $PORT_SSL"
    echo "  Dropbear Port    : 442 / 446 (SSL)"
    echo "  Squid Port       : 8080, 8181"
    echo "------------------------------------------------------"
    echo "  MySQL Host       : $HOST"
    echo "  MySQL User       : $USER"
    echo "  MySQL Database   : $DBNAME"
    echo "------------------------------------------------------"
    echo "  API Link         : $API_LINK"
    echo "  API Key          : $API_KEY"
    echo "======================================================"
    echo "  Powered By: ™YModified™"
    echo "======================================================"
    echo ""
    echo "Press Enter to reboot the server..."
    read
    reboot
}

# Main Execution Flow
server_interface=$(ip route get 8.8.8.8 | awk '/dev/ {f=NR} f&&NR-1==f' RS=" ")

install_require  
install_squid
install_openvpn
install_stunnel
# Ipakita ang Summary bago mag reboot
show_summary
